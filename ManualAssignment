//drive repository
 public async Task<bool> IsDriveCandidateValidAsync(int driveId, int driveCandidateId)
 {
     return await _context.DriveCandidates
         .AnyAsync(dc =>
             dc.DriveId == driveId &&
             dc.DriveCandidateId == driveCandidateId);
 }

//user repostory
public async Task<bool> IsUserPanelForDriveAsync(int driveId, int userId)
{
    return await _context.DriveMembers
        .AnyAsync(dm =>
            dm.UserId == userId &&
            dm.DriveId == driveId &&
            dm.RoleId == 3);
}

public async Task<DriveMember> GetDriveMemberAsync(int driveId, int userId)
{
    var driveMember = await _context.DriveMembers
        .FirstOrDefaultAsync(dm =>
            dm.UserId == userId &&
            dm.DriveId == driveId &&
            dm.RoleId == 3);

    if (driveMember == null)
        throw new Exception(ResponseMessage.DriveMemberNotFound);

    return driveMember;
}

//round repo
public async Task<bool> IsDuplicateAssignmentAsync(int driveCandidateId, int userId)
{
    return await _context.Rounds
        .AnyAsync(r =>
            r.DriveCandidateId == driveCandidateId &&
            r.Interviewer!.UserId == userId);
}

